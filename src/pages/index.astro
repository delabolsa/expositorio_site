---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogEntries from "@/components/entries/BlogEntry.astro";
import Cta from "@/components/global/Cta.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");

const tags = [...new Set(allPosts.map((post) => post.data.tags).flat())];

// Sort posts by date (newest first)
const sortedPosts = allPosts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);
---

<BaseLayout>
  <div class="py-24 text-base-950 flex flex-col items-center text-center">

    <h1 class="text-4xl text-balance font-medium font-display max-w-xl">
     Observaciones sobre artistas contemporáneos emergentes*
    </h1>
</div>

   

<!-- 🔥 HERO / BANNER CENTRAL -->
    <section class="w-full my-24 py-24 flex items-center justify-center text-center">
      <div class="max-w-3xl">

        <h2 class="text-3xl md:text-5xl font-medium">
          Espacio de exploración visual contemporánea
        </h2>

        <p class="mt-6 text-base-400 text-lg">
          Archivo digital de artistas, procesos y exposiciones. Un espacio en construcción constante.
        </p>
      </div>
    </section>
 <div class="flex flex-wrap gap-3 mt-8">
      {
        tags.map((tag) => (
          <a
            class="hover:text-blue-500 text-xs font-medium text-base-950"
            href={`/tags/${tag}`}
          >
            {tag}
          </a>
        ))
      }
    </div>
    <div class="grid grid-cols-1 mt-4 gap-8 gap-y-24 sm:grid-cols-2">
      {
        sortedPosts.map((post) => (
          <BlogEntries
            url={"/posts/" + post.id}
            alt={post.data.title}
            tags={post.data.tags}
            title={post.data.title}
            author={post.data.author}
            image={post.data.image.url}
            description={post.data.description}
            pubDate={post.data.pubDate.toString().slice(0, 10)}
          />
        ))
      }
    </div>
  <Cta />
</BaseLayout>
