---
import "../styles/global.css";
import { AstroSeo } from "@lexingtonthemes/seo";
---

<AstroSeo
  title="Expiatoriovoyeur"
  description="Sitio de arte contemporáneo y exploración visual."
  canonical="https://expiatoriovoyeur.com"
  openGraph={{
    url: "https://expiatoriovoyeur.com",
    title: "Expiatoriovoyeur",
    description: "Sitio de arte contemporáneo y exploración visual.",
    images: [
      {
        url: "https://expiatoriovoyeur.com/og-image.jpg",
        width: 1200,
        height: 630,
        alt: "Expiatoriovoyeur",
        type: "image/jpeg",
      },
    ],
    site_name: "Expiatoriovoyeur",
    type: "website",
    locale: "es_ES",
  }}
  twitter={{
    handle: "@yourhandle",
    site: "@yourhandle",
    cardType: "summary_large_image",
  }}
/>

<!-- FAVICON -->
<link rel="icon" href="/favicon.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<!-- TIPOGRAFÍAS -->
<link rel="preconnect" href="https://rsms.me/" />
<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

<link
  href="https://api.fontshare.com/v2/css?f[]=jet-brains-mono@1,2&display=swap"
  rel="stylesheet"
/>

<!-- ALPINE -->
<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
